{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "downlevelIteration": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "ES2020"
  }
}