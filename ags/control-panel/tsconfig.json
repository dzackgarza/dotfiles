{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": [
    "app.tsx",
    "env.d.ts",
    "lib/**/*.ts",
    "services/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "widget/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["@girs", "node_modules", "reminders"]
}
