set shell := ["bash", "-euo", "pipefail", "-c"]

default:
    @just --list

typecheck:
    ags types 'Astal*' --ignore Gtk3 --ignore Astal3 --update
    tsc --noEmit --skipLibCheck -p tsconfig.json

test:
    just typecheck
    python3 -m pytest tests/ -v

# Run icon infrastructure tests only
test-icons:
    python3 -m pytest tests/test_icons.py -v

run:
    ags quit || true
    ags run .
