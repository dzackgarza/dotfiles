set shell := ["bash", "-euo", "pipefail", "-c"]

default:
    @just --list

test:
    ags quit 2>/dev/null || true
    sleep 1
    just --justfile ../justfile --working-directory .. _test-control-panel

test-ci:
    just --justfile ../justfile --working-directory .. _test-ci-control-panel

run:
    ags quit || true
    ags run .

[private]
smoke-test:
    #!/usr/bin/env python3
    import subprocess, sys, tempfile, time

    subprocess.run(["ags", "quit"], capture_output=True, timeout=5)
    time.sleep(1)

    out = tempfile.NamedTemporaryFile(mode="w+", delete=False, suffix=".log")
    out_path = out.name
    proc = subprocess.Popen(
        ["ags", "run", "."],
        stdout=out,
        stderr=subprocess.STDOUT,
        text=True,
    )
    try:
        proc.wait(timeout=30)
        exited_early = True
    except subprocess.TimeoutExpired:
        proc.terminate()
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait()
        exited_early = False

    out.close()
    with open(out_path) as f:
        logs = f.read()

    if "ERR" in logs:
        print("FAIL: error logs detected")
        for line in logs.splitlines():
            if "ERR" in line:
                print(line)
        sys.exit(1)

    if "main() entry point [STARTUP]" not in logs:
        print("FAIL: app entry point did not run")
        print("Full output:")
        print(logs)
        sys.exit(1)

    if exited_early:
        print(f"FAIL: app exited during smoke window with code {proc.returncode}")
        print("Full output:")
        print(logs)
        sys.exit(1)

    print("PASS: app stayed up and emitted no error logs in 30s window")
    sys.exit(0)
