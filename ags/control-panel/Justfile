set shell := ["bash", "-euo", "pipefail", "-c"]

default:
    @just --list

test:
    just --justfile ../justfile --working-directory .. _test-control-panel

test-ci:
    just --justfile ../justfile --working-directory .. _test-ci-control-panel

run:
    ags quit || true
    ags run .

# Run AGS integration tests (requires sway compositor)
ags-test:
    ags quit || true
    @for f in tests/*.ts; do \
        echo "--- $${f} ---"; \
        ags run "$${f}" --gtk 4 2>&1 || exit 1; \
    done
    @echo "All AGS tests passed"
