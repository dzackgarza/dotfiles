# Global Pandoc & LaTeX Build System
# Include this as a module in your project justfile:
# mod pandoc '~/.pandoc/justfile'

# --- Variables ---

# Default bibliography source
GLOBAL_BIB_SOURCE := env_var_or_default("ZOTERO_GLOBAL_BIB", home_dir() / "zotero_global.bib")

# Default figures directory
GLOBAL_FIGURES_DIR := env_var_or_default("FIGURES_DIR", home_dir() / "figures")

# Build directories
BUILD_DIR_PANDOC := ".build_pandoc"
BUILD_DIR_TEX := ".build_tex"

# --- Recipes ---

# Sync bibliography from global source to local project
sync-bib local_path="references.bib" source=GLOBAL_BIB_SOURCE:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  cp {{source}} "$ROOT/{{local_path}}"

# Format markdown files to enforce one sentence per line
# Usage: just pandoc::format-md [globs/dirs...]
format-md *targets:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  
  if [ -s "$HOME/.nvm/nvm.sh" ]; then
    . "$HOME/.nvm/nvm.sh"
    nvm use node
  fi
  npm install --no-save prettier prettier-plugin-sentences-per-line
  
  # Determine targets
  FINAL_TARGETS=()
  for t in {{targets}}; do
    # Support both relative paths and direct globs
    if [[ "$t" == /* ]]; then
      FINAL_TARGETS+=("$t")
    else
      FINAL_TARGETS+=("$ROOT/$t")
    fi
  done

  if [ ${#FINAL_TARGETS[@]} -eq 0 ]; then
    echo "Usage: just pandoc::format-md <targets...>"
    exit 1
  fi

  # Resolve all targets to real files to handle symlinks correctly
  # (Prettier often fails to follow symlinks to directories or formats links themselves)
  REAL_FILES=()
  while IFS=  read -r -d $'\0'; do
      REAL_FILES+=("$REPLY")
  done < <(find "${FINAL_TARGETS[@]}" -type f -name "*.md" -exec readlink -f {} + | tr '\n' '\0' 2>/dev/null)

  if [ ${#REAL_FILES[@]} -eq 0 ]; then
    echo "No markdown files found in targets."
    exit 0
  fi

  # Use repo-local config if it exists, otherwise fall back to global ~/.pandoc/.prettierrc
  CONFIG_ARGS=()
  if [ -f "$ROOT/.prettierrc" ]; then
    CONFIG_ARGS+=(--config "$ROOT/.prettierrc")
  elif [ -f "$HOME/.pandoc/.prettierrc" ]; then
    CONFIG_ARGS+=(--config "$HOME/.pandoc/.prettierrc")
  fi

  npx prettier "${CONFIG_ARGS[@]}" --ignore-path=/dev/null --write "${REAL_FILES[@]}"

# Compile LaTeX source
compile-tex main_file="main.tex" output_name="paper" figures_dir=GLOBAL_FIGURES_DIR build_dir=BUILD_DIR_TEX:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  
  # Extract dir and file names
  DIR=$(dirname "{{main_file}}")
  FILE=$(basename "{{main_file}}")
  
  mkdir -p "$ROOT/{{build_dir}}"
  
  # Use TEXINPUTS for inclusion. Include standard ~/.pandoc paths for robustness.
  export TEXINPUTS=".:{{figures_dir}}//:$HOME/.pandoc/styles//:$HOME/.pandoc/macros//:$HOME/.pandoc/config//:${TEXINPUTS:-}"
  export BIBINPUTS=".:$ROOT//:$HOME/.pandoc/bib//:${BIBINPUTS:-}"
  
  # Change to the source directory and run latexmk
  cd "$ROOT/$DIR"
  latexmk -gg -pdf -outdir="$ROOT/{{build_dir}}" "$FILE" -use-make
  
  # Copy result back to project root
  cp "$ROOT/{{build_dir}}/${FILE%.tex}.pdf" "$ROOT/{{output_name}}-$(date +%d-%m-%y).pdf"

# Compile Pandoc source to PDF via LaTeX
compile-pandoc input_file="main.md" output_name="output" template="research_draft.tex" bibliography="references.bib" figures_dir=GLOBAL_FIGURES_DIR build_dir=BUILD_DIR_PANDOC:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  mkdir -p "$ROOT/{{build_dir}}"
  
  # Use TEXINPUTS for pandoc's latex engine as well
  export TEXINPUTS=".:{{figures_dir}}//:$HOME/.pandoc/styles//:$HOME/.pandoc/macros//:$HOME/.pandoc/config//:${TEXINPUTS:-}"

  pandoc "$ROOT/{{input_file}}" \
      --lua-filter=include.lua \
      --lua-filter=convert_amsthm_envs.lua \
      --lua-filter=select_images.lua \
      --natbib \
      --bibliography="$ROOT/{{bibliography}}" \
      --resource-path={{figures_dir}}/rendered \
      --resource-path={{figures_dir}} \
      --template={{template}} \
      --biblatex \
      --number-sections \
      --toc --toc-depth=2 \
      -s -o "$ROOT/{{build_dir}}/output.tex"
  
  cd "$ROOT/{{build_dir}}"
  latexmk -pdf -interaction=nonstopmode -gg output.tex
  cp output.pdf "$ROOT/{{output_name}}-$(date +%d-%m-%y).pdf"

# Download and extract an arXiv tarball
download-arxiv arxiv_id dir:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  mkdir -p "$ROOT/references/{{dir}}"
  wget -qO - "https://arxiv.org/e-print/{{arxiv_id}}" | tar -xz -C "$ROOT/references/{{dir}}"

# Compile a reference LaTeX file to Markdown (Modern extraction pipeline)
extract-ref dir file="main":
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  mkdir -p "$ROOT/references"
  
  cd "$ROOT/{{dir}}"
  rm -f {{file}}.aux
  
  # Expand macros
  xpandlatex -x on -m on -I on $(ls *.sty 2>/dev/null | sed 's/^/-f /' | xargs) {{file}}.tex > {{file}}_expanded.tex
  
  # Preprocess: Wrap tikzcd in displaymath
  pandoc {{file}}_expanded.tex -s -f latex+raw_tex -t latex --lua-filter=wrap_tikzcd_semantic.lua -o {{file}}_wrapped.tex
  
  # Semantically preprocess the TeX
  make4ht -c "$HOME/.pandoc/custom/config/tex4ht.cfg" -u -f html5 {{file}}_wrapped.tex "mathjax,section+" || true
  
  # Convert to Markdown
  pandoc {{file}}_wrapped.html --lua-filter=semanticlean.lua -f html -t gfm-tex_math_gfm+tex_math_dollars -o "$ROOT/references/$(basename {{dir}}).md"

# Clean build artifacts
clean build_dir_pandoc=BUILD_DIR_PANDOC build_dir_tex=BUILD_DIR_TEX:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  rm -rf "$ROOT/{{build_dir_pandoc}}" "$ROOT/{{build_dir_tex}}" "$ROOT/.build"
  rm -f "$ROOT"/*.pdf "$ROOT"/*.aux "$ROOT"/*.log "$ROOT"/*.fls "$ROOT"/*.fdb_latexmk "$ROOT"/*.bbl "$ROOT"/*.bcf "$ROOT"/*.blg "$ROOT"/*.run.xml "$ROOT"/*.out "$ROOT"/*.toc "$ROOT"/*SAVE-ERROR

# Clean all build artifacts from reference directories
clean-refs:
  #!/usr/bin/env bash
  set -euo pipefail
  ROOT="{{invocation_directory()}}"
  find "$ROOT/references" -type f ! \( -name "*.tex" -o -name "*.sty" -o -name "*.cls" -o -name "*.bib" -o -name "*.bbl" -o -name "*.png" -o -name "*.jpg" -o -name "tex4ht.cfg" \) -delete
