  doi = {10.48550/arXiv.1703.09855},
  url = {http://arxiv.org/abs/1703.09855},
  urldate = {2022-06-09},
  abstract = {We lift the classical Hasse--Weil zeta function of varieties over a finite field to a map of spectra with domain the Grothendieck spectrum of varieties constructed by Campbell and Zakharevich. We use this map to prove that the Grothendieck spectrum of varieties contains nontrivial geometric information in its higher homotopy groups by showing that the map \$\textbackslash mathbb\textbraceleft S\textbraceright{} \textbackslash to K(Var\_k)\$ induced by the inclusion of \$0\$-dimensional varieties is not surjective on \$\textbackslash pi\_1\$ for a wide range of fields \$k\$. The methods used in this paper should generalize to lifting other motivic measures to maps of \$K\$-theory spectra.},
  archiveprefix = {arXiv},
