@article{SZ20,
  title = {L-{{Equivalence}} for {{Degree Five Elliptic Curves}}, {{Elliptic Fibrations}} and {{K3 Surfaces}}},
  author = {Shinder, Evgeny and Zhang, Ziyu},
  year = 2020,
  month = apr,
  journal = {Bulletin of the London Mathematical Society},
