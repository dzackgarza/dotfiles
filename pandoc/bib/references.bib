@book{DK24,
  title = {Enriques {{Surfaces II}}},
  author = {Dolgachev, Igor and Kond{\=o}, Shigeyuki, Shigeyuki},
  year = 2024,
  abstract = {This work provides a contemporary account of Enriques surfaces, focusing on their classification and automorphism groups, particularly over fields of arbitrary characteristic. We introduce the notion of canonical isotropic sequences and the non-degeneracy invariant of an Enriques surface, proving that the non-degeneracy invariant is at least 3 in characteristic not equal to 2. We classify extra-special Enriques surfaces in characteristic 2, characterized by a non-degeneracy invariant of at most 2. We then study Reye congruences, providing a novel construction in characteristic 2 and relating them to Enriques surfaces. A key contribution is a detailed analysis of automorphisms of Enriques surfaces, including a geometric reproof of the Barth-Peters-Nikulin result on the automorphism group of a general Enriques surface, extended to general nodal surfaces. We classify Enriques surfaces with finite automorphism groups, providing a complete classification over fields of characteristic zero and a detailed exposition of recent classifications over fields of arbitrary characteristic. The theory of rational Coble surfaces, close cousins of Enriques surfaces, is developed, including the introduction of the Coble-Mukai lattice and a classification of Coble surfaces with finite automorphism group. Finally, we investigate classical and \$\textbackslash alpha\_2\$-Enriques surfaces in characteristic 2, whose canonical cover is birationally isomorphic to a supersingular K3 surface. We discuss the periods of such surfaces and Ogus's Global Torelli Theorem, and classify Enriques and Coble surfaces whose canonical cover is birationally isomorphic to a supersingular K3 surface of Artin invariant \$\textbackslash sigma\_0 = 1\$.},
  timestamp = {2025-09-03T22:50:32Z},
  file = {DK24_middle.json:/home/dzack/Zotero/storage/2KZZX7FD/[Dolgachev 2024] Enriques Surfaces II_middle.json:application/json;DK24_extracted.md:/home/dzack/Zotero/storage/7RZTF9AQ/[Dolgachev 2024] Enriques Surfaces II.md:text/markdown;DK24_content_list.json:/home/dzack/Zotero/storage/RK8F8MTT/[Dolgachev 2024] Enriques Surfaces II_content_list.json:application/json;[Dolgachev 2024] Enriques Surfaces II:/home/dzack/Zotero/storage/V3WS4ENC/[Dolgachev 2024] Enriques Surfaces II.pdf:application/pdf}
