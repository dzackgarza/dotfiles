  author = {Campbell, Jonathan A. and Zakharevich, Inna},
  year = 2018,
  month = nov,
  doi = {10.48550/arXiv.1811.08014},
  url = {https://arxiv.org/abs/1811.08014v4},
  urldate = {2022-06-07},
  abstract = {We introduce a new perspective on the \$K\$-theory of exact categories via the notion of a CGW-category. CGW-categories are a generalization of exact categories that admit a Qullen \$Q\$-construction, but which also include examples such as finite sets and varieties. By analyzing Quillen's proofs of d\textbackslash 'evissage and localization we define ACGW-categories, an analogous generalization of abelian categories for which we prove theorems analogous to d\textbackslash 'evissage and localization. In particular, although the category of varieties is not quite ACGW, the category of reduced schemes of finite type is; applying d\textbackslash 'evissage and localization allows us to calculate a filtration on the \$K\$-theory of schemes of finite type. As an application of this theory we construct a comparison map showing that the two authors' definitions of the Grothendieck spectrum of varieties are equivalent.},
  langid = {english},
  timestamp = {2026-06-10T17:50:45Z},
  file = {[Campbell 2018] Devissage and Localization for the Grothendieck Spectrum of Varieties:/home/dzack/Zotero/storage/23HIWF7A/[Campbell 2018] Devissage and Localization for the Grothendieck Spectrum of Varieties.pdf:application/pdf;CZ18_middle.json:/home/dzack/Zotero/storage/AEMB59TU/[Campbell 2018] Devissage and Localization for the Grothendieck Spectrum of Varieties_middle.json:application/json;CZ18_content_list.json:/home/dzack/Zotero/storage/GIUNK6LT/[Campbell 2018] Devissage and Localization for the Grothendieck Spectrum of Varieties_content_list.json:application/json;CZ18_extracted.md:/home/dzack/Zotero/storage/P5YJSWIK/[Campbell 2018] Devissage and Localization for the Grothendieck Spectrum of Varieties.md:text/markdown}
