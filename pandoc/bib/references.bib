@book{BPV84,
  title = {Compact {{Complex Surfaces}}},
  author = {Barth, W. and Peters, C. and {de Ven}, A. Van},
  year = 1984,
  series = {{{ERGMG}}},
  publisher = {Springer-Verlag},
  abstract = {This monograph provides a comprehensive and self-contained treatment of the Enriques-Kodaira classification of compact complex surfaces. Beginning with foundational material on complex manifolds, algebraic topology, and sheaf theory, the text develops the necessary tools for studying curves on surfaces, bimeromorphic transformations, and elliptic fibrations. A key result is the proof of Iitaka's \$C\_\textbraceleft 2,1\textbraceright\$ conjecture, establishing a fundamental relationship between the Kodaira dimensions of a surface and its fibration structure. The book then delves into the classification itself, characterizing minimal surfaces based on their Kodaira dimension and algebraic dimension. Special attention is given to K3-surfaces and Enriques surfaces, including a detailed exploration of their Torelli theorems and moduli spaces. The text culminates in a discussion of surfaces of general type, presenting Reider's method for analyzing pluricanonical maps and exploring the geography of Chern numbers. This second edition incorporates significant advancements since the original publication, including a direct proof of the K\"ahler nature of surfaces with even first Betti number, an exposition of Reider's method, and an overview of Donaldson and Seiberg-Witten invariants and their implications for the differentiable topology of algebraic surfaces. The book also includes a new chapter with applications of K3-surfaces to mirror symmetry, the existence of rational and elliptic curves, and hyperbolic geometry.},
  date-modified = {2012-12-26 19:59:11 +0000},
  lccn = {QA571.B37 1984},
