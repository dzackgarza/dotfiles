@book{GH78,
  title = {Principles of {{Algebraic Geometry}}},
  author = {Griffiths, P. and Harris, J.},
  year = 1978,
  publisher = {Wiley-Interscience},
  abstract = {This paper presents a detailed exploration of algebraic geometry, focusing on complex manifolds and algebraic varieties. Foundational material from complex analysis, topology, and differential geometry is reviewed, including the Weierstrass theorems, sheaf theory, intersection theory, and Hodge theory. The local properties of analytic varieties are examined, with emphasis on analytic hypersurfaces and the Riemann extension theorem. Complex manifolds are introduced, along with the concepts of holomorphic tangent spaces and submanifolds. The paper then delves into the Weierstrass division theorem and the weak Nullstellensatz. The core of the work centers on the study of divisors and line bundles, including Chern classes and the Kodaira vanishing theorem. The Kodaira embedding theorem is presented, providing a criterion for algebraic varieties. The Grassmannian is introduced as a tool for parametrizing linear subspaces, and the Schubert calculus is developed. The theory is then applied to Riemann surfaces and algebraic curves, with a focus on Abel's theorem, the Riemann-Roch formula, and canonical curves. Plucker formulas and correspondences are explored, leading to a discussion of complex tori and Abelian varieties, including the Riemann conditions and theta-functions. Torelli's theorem is stated, relating curves to their Jacobians. Further techniques are developed, including distributions, currents, and their applications to complex analysis. Chern classes are defined, and the Gauss-Bonnet formulas are derived. Fixed-point and residue formulas are presented, culminating in the general Hirzebruch-Riemann-Roch formula. Spectral sequences are introduced and applied to hypercohomology and differentials of the second kind. The paper then turns to the study of algebraic surfaces, covering intersection numbers, blowing up and down, rational maps, and the classification of surfaces. Rational surfaces are examined in detail, including Noether's lemma, ruled surfaces, and surfaces of minimal degree. Irrational surfaces are introduced, with a focus on the Albanese map, ruled surfaces, and elliptic surfaces. Noether's formula for general surfaces is proved, and examples of isolated singularities are discussed. The theory of residues is further developed, with elementary properties, the global residue theorem, and the transformation law. Applications of residues are given, including intersection numbers and finite holomorphic mappings. Rudiments of commutative and homological algebra are presented, including the Koszul complex and coherent sheaves. Global duality is explored, with applications to vector fields and points on a surface. Finally, the quadric line complex is studied in detail, including the geometry of the Grassmannian, line complexes, and the associated Kummer surface. The variety of lines on the quadric line complex is examined, and the group law is derived. The rationality of the quadric line complex is discussed.},
  date-modified = {2012-12-26 19:59:11 +0000},
  timestamp = {2025-09-03T22:50:41Z},
  file = {GH78_content_list.json:/home/dzack/Zotero/storage/96LMVPIV/Griffiths and Harris - 1978 - Principles of Algebraic Geometry_content_list.json:application/json;GH78_extracted.md:/home/dzack/Zotero/storage/M5BYZPU3/Griffiths and Harris - 1978 - Principles of Algebraic Geometry.md:text/markdown;PDF:/home/dzack/Zotero/storage/PP343YU3/Griffiths and Harris - 1978 - Principles of Algebraic Geometry.pdf:application/pdf;GH78_middle.json:/home/dzack/Zotero/storage/UB4BAL8U/Griffiths and Harris - 1978 - Principles of Algebraic Geometry_middle.json:application/json}
