@article{Cox35,
  ids = {Cox35a},
  title = {Wythoff's {{Construction}} for {{Uniform Polytopes}}},
  author = {Coxeter, H. S. M.},
  year = 1935,
  journal = {Proc. London Math. Soc. (2)},
  volume = {38},
  number = {1},
  pages = {327--339},
  issn = {0024-6115},
  doi = {10.1112/plms/s2-38.1.327},
  url = {https://doi.org/10.1112/plms/s2-38.1.327},
  urldate = {2024-01-28},
  abstract = {This paper provides a systematic application of Wythoff's construction to generate uniform polytopes. A uniform polytope is defined as a polytope with regular faces and a symmetry group transitive on its vertices. The paper exhaustively applies Wythoff's construction, encompassing the polytopes previously discovered by Schlafli, Gosset, Stott, Schoute, and Elte, and extending to a multitude of new polytopes. The fundamental region of a discrete group generated by reflections is represented by a graph, where nodes correspond to generators and links denote dihedral angles. A key aspect of the construction involves associating polytopes with ringed dots on these graphs, symbolizing vertices derived from the fundamental region. The paper establishes a symbolic notation for these polytopes, extending existing notations such as \$t\_\textbraceleft f,g,\textbackslash dots,l\textbraceright\textbackslash\textbraceleft k\_1, k\_2, \textbackslash dots, k\_\textbraceleft m-1\textbraceright\textbackslash\textbraceright\$ and \$(n\_\textbraceleft r,\textbackslash dots,t\textbraceright p\_\textbraceleft u,\textbackslash dots,w\textbraceright q\_\textbraceleft x,\textbackslash dots,z\textbraceright )\$. Explicit connections are made between the Wythoff construction and Stott's operations. The paper enumerates the elements of the constructed polytopes, providing a method for calculating the number of vertices and incident elements. Finally, the paper introduces a construction for snub polytopes, obtained by taking vertices in regions of one color, and relates this construction to the golden section in specific cases. Several new polytopes, including \$q\textbackslash delta\_m\$, are presented, along with their vertex figures and associated properties.},
  fjournal = {Proceedings of the London Mathematical Society. Second Series},
  mrclass = {DML},
  mrnumber = {1576319},
  timestamp = {2026-06-10T17:52:50Z},
  file = {Cox35_extracted.md:/home/dzack/Zotero/storage/7TYCVFT3/[Coxeter 1935] Wythoff's Construction for Uniform Polytopes.md:text/markdown;Cox35_content_list.json:/home/dzack/Zotero/storage/GX7RWEGZ/[Coxeter 1935] Wythoff's Construction for Uniform Polytopes_content_list.json:application/json;[Coxeter 1935] Wythoff's Construction for Uniform Polytopes:/home/dzack/Zotero/storage/NDZ758RZ/[Coxeter 1935] Wythoff's Construction for Uniform Polytopes.pdf:application/pdf;Cox35_middle.json:/home/dzack/Zotero/storage/QYA92JHZ/[Coxeter 1935] Wythoff's Construction for Uniform Polytopes_middle.json:application/json}
