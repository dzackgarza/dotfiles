  url = {https://arxiv.org/abs/2006.11238},
  abstract = {In this paper we investigate the geometry of projective varieties polarised by ample and more generally nef and big Weil divisors. First we study birational boundedness of linear systems. We show that if X is a projective variety of dimension d with -lc Fano variety of dimension d then taking N=-K\textsubscript{X} we recover birationality of \textbar -mK\textsubscript{X}\textbar{} for bounded m. We prove similar birational boundedness results for nef and big Weil divisors N on projective klt varieties X when both K\textsubscript{X} and N-K\textsubscript{X} are pseudo-effective (here X is not assumed \$\$-lc). Using the above, we show boundedness of polarised varieties under some natural conditions. We extend these to boundedness of semi-log canonical Calabi-Yau pairs polarised by effective ample Weil divisors not containing lc centres. We will briefly discuss applications to existence of projective coarse moduli spaces of such polarised Calabi-Yau pairs.},
