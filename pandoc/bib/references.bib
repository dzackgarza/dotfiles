@book{FM13,
  title = {Handbook of {{Moduli}}},
  author = {Farkas, Gavril and Morrison, Ian},
  year = 2013,
  publisher = {International Press\,; Higher Education Press of China},
  address = {Somerville, MA, Beijing, China},
  abstract = {This paper provides a handbook on moduli spaces, focusing on K3 surfaces and irreducible symplectic manifolds. We review the theory of K3 surfaces, including markings, the period map, and the Torelli theorem. We define irreducible symplectic manifolds and discuss their known examples, Beauville form, and Fujiki invariant. We present the Hodge-theoretic Torelli theorem for irreducible symplectic manifolds, as recently proved by Verbitsky, and its implications for moduli spaces. We describe the construction of moduli spaces of polarized K3 surfaces and irreducible symplectic manifolds as quotients of homogeneous domains, and discuss GIT constructions. We examine compactifications of these moduli spaces, including Baily-Borel and toroidal compactifications, and analyze the singularities that arise. We provide a detailed treatment of modular forms of orthogonal type, rational quadratic divisors, and the low weight cusp form trick. We introduce the quasi pull-back of modular forms and prove that non-trivial quasi pull-backs are cusp forms. We present a detailed description of quasi pull-back of automorphic Borcherds products. We collect and discuss the relevant facts from the theory of modular forms with respect to the orthogonal group \$\textbackslash mathrm \textbraceleft{} O \textbraceright{} ( 2 , \textbraceleft{} \textbackslash mathfrak \textbraceleft{} n \textbraceright{} \textbraceright{} )\$. We also give a detailed description of quasi pull-back of automorphic Borcherds products. This part contains previously unpublished results. Finally, we investigate the arithmetic of root systems and binary quadratic forms in \$\textbackslash mathsf \textbraceleft{} E \textbraceright{} \_ \textbraceleft{} 8 \textbraceright\$ , and apply these results to determine the Kodaira dimension of certain moduli spaces.},
  timestamp = {2025-09-03T22:50:36Z},
  file = {FM13_extracted.md:/home/dzack/Zotero/storage/5C766LI9/Farkas and Morrison - 2013 - Handbook of Moduli.md:text/markdown;FM13_content_list.json:/home/dzack/Zotero/storage/9IEWDT6W/Farkas and Morrison - 2013 - Handbook of Moduli_content_list.json:application/json;FM13_middle.json:/home/dzack/Zotero/storage/QVWWX8JS/Farkas and Morrison - 2013 - Handbook of Moduli_middle.json:application/json;PDF:/home/dzack/Zotero/storage/WGWLD6FF/Farkas and Morrison - 2013 - Handbook of Moduli.pdf:application/pdf}
