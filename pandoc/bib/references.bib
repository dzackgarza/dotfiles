@book{CLS11,
  ids = {CLS11a},
  title = {Toric {{Varieties}}},
  author = {Cox, David A. and Little, John B. and Schenck, Hal},
  year = 2011,
  series = {Graduate Studies in Mathematics},
  volume = {124},
  pages = {xxiv+841},
  publisher = {American Mathematical Society},
  address = {Providence},
  doi = {10.1090/gsm/124},
  url = {http://dx.doi.org/10.1090/gsm/124},
  abstract = {This paper provides a comprehensive introduction to the theory of toric varieties, bridging the gap between elementary algebraic geometry and current research. We begin by establishing the fundamental correspondence between affine toric varieties and finitely generated semigroups, and extend this to projective and normal toric varieties via cones and fans. We introduce Weil and Cartier divisors, and develop the homogeneous coordinate ring as a powerful tool for studying sheaves on toric varieties. We then relate Cartier divisors to invertible sheaves, and describe the structure of the nef and Mori cones. Projective toric morphisms are classified in terms of polyhedra, and we provide an explicit description of the canonical divisor. We present two methods for computing sheaf cohomology, and prove a range of vanishing theorems, with applications to lattice polytopes. The classical theory of toric surfaces is then explored, including continued fractions, resolutions of singularities, Gr\textasciidieresis obner fans, and the McKay correspondence. We compute the singular and equivariant cohomology of complete simplicial toric varieties, and prove the Hirzebruch-Riemann-Roch and equivariant Riemann-Roch theorems. Finally, we explore the connections between geometric invariant theory, the secondary fan, Gale duality, and the toric minimal model program. This work culminates in a detailed exposition of toric GIT, providing a powerful framework for understanding the moduli spaces of toric varieties.},
  isbn = {978-0-8218-4819-7},
  mrclass = {14M25 (05A15 05E45 52B12)},
  mrnumber = {2810322 (2012g:14094)},
  mrreviewer = {Ivan V. Arzhantsev},
  timestamp = {2025-09-03T22:50:29Z},
  file = {[Cox 2011] Toric varieties:/home/dzack/Zotero/storage/36JNSE8G/[Cox 2011] Toric varieties.pdf:application/pdf;CLS11_extracted.md:/home/dzack/Zotero/storage/5T5IG2FE/[Cox 2011] Toric varieties.md:text/markdown;CLS11_middle.json:/home/dzack/Zotero/storage/GREIBU25/[Cox 2011] Toric varieties_middle.json:application/json;CLS11_content_list.json:/home/dzack/Zotero/storage/NDGUP9UP/[Cox 2011] Toric varieties_content_list.json:application/json}
