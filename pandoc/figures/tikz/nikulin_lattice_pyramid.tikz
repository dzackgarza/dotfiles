\node[pt01] at (10,6) {};
\node[pt01] at (14,6) {};
% a=8
\node[pt01] at (10,8) {};
% a=10
\node[pt01] at (10,10) {};

% delta = 1 only
% a=11
\node[pt1] at (11,11) {};
% a=10
\node[pt1] at (12,10) {};
% a=9
\node[pt1] at (9,9)  {};
\node[pt1] at (11,9) {};
\node[pt1] at (13,9) {};
% a=8
\node[pt1] at (8,8)  {};
