\node[pt01] at (2,2)  {};
\node[pt01] at (10,2) {};
\node[pt01] at (18,2) {};
% a=4
\node[pt01] at (6,4)  {};
\node[pt01] at (10,4) {};
\node[pt01] at (14,4) {};
\node[pt01] at (18,4) {};
