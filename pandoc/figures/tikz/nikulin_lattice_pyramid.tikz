\node[pt1] at (12,6) {};
\node[pt1] at (16,6) {};
% a=5
\node[pt1] at (5,5)  {};
\node[pt1] at (7,5)  {};
\node[pt1] at (9,5)  {};
\node[pt1] at (11,5) {};
\node[pt1] at (13,5) {};
\node[pt1] at (15,5) {};
\node[pt1] at (17,5) {};
