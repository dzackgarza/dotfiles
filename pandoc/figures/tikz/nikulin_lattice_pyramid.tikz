\begin{tikzpicture}[
  x=0.6cm,
  y=0.6cm,
  >=Triangle,
  line cap=round,
  line join=round,
  axis/.style={black, line width=1pt},
  tick/.style={black, line width=0.8pt},
  coordgrid/.style={gray!50, line width=0.25pt},
  pt1/.style={circle, fill=black, draw=black, inner sep=0pt, minimum size=4.2pt},
  pt0/.style={circle, fill=white, draw=black, inner sep=0pt, minimum size=5.8pt, line width=0.8pt},
  pt01/.style={circle, double, fill=white, draw=black, inner sep=0pt, minimum size=7.0pt, line width=0.8pt, double distance=0.9pt},
  lbl/.style={black, font=\scriptsize}
]

% background grid
\draw[coordgrid,step=1] (0,0) grid (22,12);

% axes: origin at (0,0) so that r=0 is the axis start
\draw[axis, ->] (0,0) -- (22.1,0) node[right] {$r$};
\draw[axis, ->] (0,0) -- (0,12.0) node[above] {$a$};

% slanted g- and k-axes / boundary
\draw[axis, <-] (0.5,0.5) -- (11,11) -- (20,2);
\draw[axis, ->] (20,2) -- (21.15,0.85);

% x-axis ticks and labels
\foreach \r in {0,...,21}{
  \draw[tick] (\r,0.12) -- (\r,-0.12);
  \node[lbl, below=2pt] at (\r,0) {\r};
}

% y-axis ticks and labels
\foreach \a in {1,...,11}{
  \draw[tick] (-0.12,\a) -- (0.12,\a);
  \node[lbl, left=4pt] at (0,\a) {\a};
}

% delta = 0 only
\node[pt0] at (2,0)  {};
\node[pt0] at (10,0) {};
\node[pt0] at (18,0) {};
\node[pt0] at (6,2)  {};
\node[pt0] at (14,2) {};


