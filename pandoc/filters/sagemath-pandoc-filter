#!/usr/bin/env bash
# sagemath-pandoc-filter — Global Pandoc filter wrapper.
# Runs the actual filter under Sage's Python interpreter, which has both
# `sage.all` and `panflute` installed.

set -euo pipefail

PKG_ROOT="${HOME}/notes/teaching/sage_filter_package"

exec sage --python -c "
import sys
sys.path.insert(0, '${PKG_ROOT}')
from sagemath_pandoc_filter.filter import main
main()
"
