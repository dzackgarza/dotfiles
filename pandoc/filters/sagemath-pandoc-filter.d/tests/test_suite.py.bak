"""Comprehensive test suite for Sage plot generation and embedding.

This module provides a unified test runner that executes all test cases
and generates a detailed compliance report.
"""

import os
import sys
import base64
import json
import importlib
import subprocess
from pathlib import Path
from datetime import datetime
from typing import Dict, List, Tuple, Any, Optional, Callable, Type, Set

# Add package to path
PACKAGE_DIR = Path(__file__).parent.parent
if str(PACKAGE_DIR) not in sys.path:
    sys.path.insert(0, str(PACKAGE_DIR))

from sage_filter.sage_runner import execute_sage_code

# ANSI color codes for terminal output
GREEN = "\033[92m"
YELLOW = "\033[93m"
RED = "\033[91m"
RESET = "\033[0m"
BOLD = "\033[1m"
UNDERLINE = "\033[4m"
class TestResult:
    """Container for test results."""
    def __init__(self, name: str):
        self.name = name
        self.passed = False
        self.error = None
        self.duration = 0.0
        self.output = None
        self.start_time = datetime.now()

    def __str__(self):
        status = f"{GREEN}✓{RESET}" if self.passed else f"{RED}✗{RESET}"
        return f"  {status} {self.name:60} {'PASSED' if self.passed else 'FAILED'}"


def run_test(test_func: Callable) -> TestResult:
    """Run a single test and return the result."""
    test_name = test_func.__name__.replace('_', ' ').title()
    result = TestResult(test_name)
    start_time = datetime.now()
    
    try:
        output = test_func()
        result.passed = True
        result.output = output
    except Exception as e:
        result.error = str(e)
        result.passed = False
    finally:
        result.duration = (datetime.now() - start_time).total_seconds()
    
    return result


def find_test_modules():
    """Find all test modules in the tests directory."""
    test_modules = set()
    tests_dir = Path(__file__).parent
    
    # Add tests in the root directory
    for path in tests_dir.glob('test_*.py'):
        module_name = path.stem
        test_modules.add(module_name)
    
    # Add tests in subdirectories
    for path in tests_dir.rglob('test_*.py'):
        # Convert path to module name (e.g., 'unit/test_foo.py' -> 'unit.test_foo')
        rel_path = path.relative_to(tests_dir)
        module_parts = list(rel_path.parts)
        module_parts[-1] = module_parts[-1][:-3]  # Remove .py
        module_name = '.'.join(module_parts)
        test_modules.add(module_name)
    
    return sorted(test_modules)

def run_test_module(module_name: str) -> List[TestResult]:
    """Run all tests in a module."""
    results = []
    
    try:
        print(f"\n{BOLD}Running tests in {module_name}...{RESET}")
        module = importlib.import_module(f"tests.{module_name}")
        
        for name in dir(module):
            if name.startswith('test_') and callable(getattr(module, name)):
                test_func = getattr(module, name)
                result = run_test(test_func)
                results.append(result)
                print(f"{result}")
                if not result.passed and result.error:
                    print(f"    {RED}Error:{RESET} {result.error}")
    except Exception as e:
        print(f"{RED}Error loading module {module_name}: {e}{RESET}")
        result = TestResult(f"Module {module_name}")
        result.passed = False
        result.error = str(e)
        results.append(result)
    
    return results


def run_tests():
    """Run all tests and print a summary."""
    print(f"{BOLD}Sage Filter Test Suite{RESET}")
    print(f"Python: {sys.version.split()[0]}")
    print(f"Working directory: {os.getcwd()}")
    print(f"Package directory: {PACKAGE_DIR}")
    
    # Check Sage version
    try:
        sage_version = subprocess.check_output(['sage', '--version']).decode().strip()
        print(f"Sage version: {sage_version}")
    except (subprocess.SubprocessError, FileNotFoundError):
        print(f"{YELLOW}Warning: Could not determine Sage version. Make sure 'sage' is in your PATH.{RESET}")
    
    print(f"\n{BOLD}Test Suite Summary{RESET}")
    start_time = datetime.now()
    print(f"Started at:  {start_time.isoformat()}")
    
    # Run all test modules
    all_results = []
    
    # List of all test modules to run
    test_modules = [
        # Core functionality tests
        'test_plot_generation',
        'test_html_embedding',
        'test_expectations',
        'test_pdf_output',
        'test_pdf_output_fixed',
        'test_sage_pdf_output',
        
        # Unit tests
        'unit.test_basic_math',
        
        # Integration tests
        'integration.test_symbolic_math',
        
        # Regression tests
        'regression.test_regressions',
    ]
    
    # Run all test modules
    for module_name in test_modules:
        try:
            all_results.extend(run_test_module(module_name))
        except ModuleNotFoundError as e:
            print(f"{YELLOW}Warning: Could not load test module {module_name}: {e}{RESET}")
    
    # Calculate statistics
    duration = datetime.now() - start_time
    total = len(all_results)
    passed = sum(1 for r in all_results if r.passed)
    failed = total - passed
    
    # Print detailed results
    print(f"\n{BOLD}Detailed Results:{RESET}")
    for i, result in enumerate(all_results, 1):
        status = f"{GREEN}✓{RESET}" if result.passed else f"{RED}✗{RESET}"
        print(f"{i:4d}. {result.name:60} {status} {result.duration:.3f}s")
        if not result.passed and result.error:
            print(f"      {RED}Error:{RESET} {result.error}")
    
    # Print summary
    print(f"\n{BOLD}Test Suite Summary{RESET}")
    print(f"Started at:  {start_time.isoformat()}")
    print(f"Duration:    {duration.total_seconds():.3f} seconds")
    print(f"Total tests: {total}")
    print(f"{GREEN}✓ Passed:     {passed}{RESET}")
    if failed > 0:
        print(f"{RED}✗ Failed:     {failed}{RESET}")
    success_rate = (passed / total * 100) if total > 0 else 0
    color = GREEN if success_rate > 90 else YELLOW if success_rate > 50 else RED
    print(f"{BOLD}Success rate:{RESET} {color}{success_rate:.1f}%{RESET}")
    
    # Exit with non-zero code if any tests failed
    sys.exit(1 if failed > 0 else 0)


def run_plot_generation_tests(result: TestResult) -> None:
    """Run all plot generation tests."""
    # Test data for different types of plots
    test_cases = [
        # 1. Basic 2D plot
        ("Basic 2D Plot (Quadratic)", """
from sage.all import plot, var
x = var('x')
plot(x**2, (x, -2, 2), title='Quadratic Function')
""", "Quadratic Function"),
        
        # 2. Multiple curves
        ("Multiple Curves (Sine and Cosine)", """
from sage.all import plot, var, sin, cos, pi
x = var('x')
p1 = plot(sin(x), (x, -pi, pi), color='red', legend_label='sin(x)')
p2 = plot(cos(x), (x, -pi, pi), color='blue', legend_label='cos(x)')
p1 + p2
""", None),
        
        # 3. 3D surface plot
        ("3D Surface Plot (Paraboloid)", """
from sage.all import var, plot3d
x, y = var('x y')
plot3d(x**2 + y**2, (x, -2, 2), (y, -2, 2), title='3D Paraboloid')
""", "3D Paraboloid"),
        
        # 4. Contour plot
        ("Contour Plot", """
from sage.all import contour_plot, var
x, y = var('x y')
contour_plot(x**2 + y**2, (x, -2, 2), (y, -2, 2), title='Contour Plot')
""", "Contour Plot"),
        
        # 5. Parametric plot
        ("Parametric Plot", """
from sage.all import parametric_plot, var, cos, sin, pi
var('t')
parametric_plot((cos(t), sin(t) + cos(1.5*t)), (t, 0, 4*pi), color='purple')
""", None),
        
        # 6. Polar plot
        ("Polar Plot", """
from sage.all import polar_plot, var, sin, pi
var('theta')
polar_plot(sin(3*theta), (0, 2*pi), color='green')
""", None),
        
        # 7. Vector field plot
        ("Vector Field Plot", """
from sage.all import plot_vector_field, var
x, y = var('x y')
plot_vector_field((x, -y), (x, -2, 2), (y, -2, 2), color='blue')
""", None),
        
        # 8. Implicit plot
        ("Implicit Plot", """
from sage.all import var, implicit_plot
x, y = var('x y')
implicit_plot(x**2 + y**2 - 1, (x, -2, 2), (y, -2, 2), color='red')
""", None),
        
        # 9. Histogram
        ("Histogram", """
from sage.all import histogram, random
import numpy as np
histogram([random() for _ in range(1000)], bins=20, color='teal')
""", None),
        
        # 10. Scatter plot
        ("Scatter Plot", """
from sage.all import scatter_plot, random
points = [(random(), random()) for _ in range(100)]
scatter_plot(points, facecolor='orange', edgecolor='black')
""", None),
        
        # 11. Complex plot
        ("Complex Plot", """
from sage.all import complex_plot, var
var('z')
complex_plot(z**2, (-2, 2), (-2, 2), plot_points=100)
""", None),
        
        # 12. Density plot
        ("Density Plot", """
from sage.all import density_plot, var
x, y = var('x y')
density_plot(x**2 + y**2, (x, -2, 2), (y, -2, 2), cmap='viridis')
""", None),
        
        # 13. Bar chart
        ("Bar Chart", """
from sage.all import bar_chart
bar_chart([1, 2, 3, 4, 5], color='lightblue')
""", None),
        
        # 14. Pie chart (using bar chart as pie_chart is not available)
        ("Pie Chart (as Bar Chart)", """
from sage.all import bar_chart
bar_chart([0.3, 0.2, 0.5], color=['red', 'green', 'blue'])
""", None),
        
        # 15. Step function plot (using line plot)
        ("Step Function Plot", """
from sage.all import line
# Create step function points
points = [(0,1), (1,1), (1,2), (2,2), (2,1), (3,1)]
line(points, color='purple', thickness=2)
""", None)
    ]
    
    for name, plot_code, expected_title in test_cases:
        try:
            # Execute the plot generation
            test_result = execute_sage_code(plot_code.strip())
            
            # Verify basic result structure
            assert test_result['success'], f"Plot generation failed: {test_result.get('error', 'Unknown error')}"
            assert isinstance(test_result['result'], dict), "Result should be a dictionary"
            
            plot_data = test_result['result']
            
            # Check required fields
            assert 'type' in plot_data, "Missing 'type' field in plot data"
            assert plot_data['type'] == 'plot', f"Expected type 'plot', got {plot_data['type']}"
            
            # Check title if expected
            if expected_title is not None:
                assert plot_data.get('title') in [expected_title, 'Plot'], \
                       f"Expected title '{expected_title}' or 'Plot', got '{plot_data.get('title')}'"
            
            # Verify image file
            assert 'image_file' in plot_data, "Missing 'image_file' field in plot data"
            image_path = plot_data['image_file']
            assert os.path.exists(image_path), f"Image file not found: {image_path}"
            
            # Verify file size and content
            file_size = os.path.getsize(image_path)
            assert file_size > 1000, f"Image file too small: {file_size} bytes"
            
            with open(image_path, 'rb') as f:
                file_content = f.read()
            
            # Check for common image file signatures
            signatures = [
                b'\x89PNG',  # PNG
                b'\xff\xd8',  # JPEG
                b'%PDF',      # PDF
                b'<svg'       # SVG
            ]
            
            is_valid = any(file_content.startswith(sig) for sig in signatures)
            if not is_valid:
                # If no standard signature found, check if it's likely binary
                is_valid = any(b'\x00' in file_content[:100] or (b > 127 for b in file_content[:100]))
            
            assert is_valid, "File does not appear to be a valid image"
            
            # Clean up
            try:
                os.remove(image_path)
            except OSError:
                pass
            
            result.add_test_case(
                name=name,
                passed=True,
                message=f"Successfully generated {os.path.splitext(image_path)[1].upper().lstrip('.')} file ({file_size} bytes)"
            )
            
        except AssertionError as e:
            result.add_test_case(
                name=name,
                passed=False,
                message=str(e),
                details=f"Code:\n{plot_code}"
            )
        except Exception as e:
            result.add_test_case(
                name=name,
                passed=False,
                message=f"Unexpected error: {str(e)}",
                details=f"Code:\n{plot_code}"
            )


def run_html_embedding_test(result: TestResult) -> None:
    """Test embedding plots in HTML with data URIs."""
    test_name = "HTML Embedding with Data URI"
    
    try:
        # Create a simple plot
        plot_code = """
        from sage.all import plot, var, sin, pi
        x = var('x')
        plot(sin(x), (x, 0, 2*pi), title='Sine Wave')
        """
        
        # Generate the plot
        plot_result = execute_sage_code(plot_code.strip())
        assert plot_result['success'], f"Plot generation failed: {plot_result.get('error', 'Unknown error')}"
        
        plot_data = plot_result['result']
        image_path = plot_data['image_file']
        
        try:
            # Read the image data
            with open(image_path, 'rb') as f:
                image_data = f.read()
            
            # Get the MIME type based on file extension
            ext = os.path.splitext(image_path)[1].lower().lstrip('.')
            mime_types = {
                'png': 'image/png',
                'jpg': 'image/jpeg',
                'jpeg': 'image/jpeg',
                'svg': 'image/svg+xml',
                'pdf': 'application/pdf'
            }
            mime_type = mime_types.get(ext, 'application/octet-stream')
            
            # Create data URI
            encoded_data = base64.b64encode(image_data).decode('ascii')
            
            # Verify the encoded data looks reasonable
            assert len(encoded_data) > 1000, f"Encoded data too small: {len(encoded_data)} characters"
            assert len(encoded_data) < 10 * 1024 * 1024, f"Encoded data too large: {len(encoded_data) / (1024*1024):.1f} MB"
            
            # Create HTML with the embedded image
            html = f"""<!DOCTYPE html>
            <html>
            <head>
                <title>Embedded Plot Test</title>
            </head>
            <body>
                <h1>Test Plot</h1>
                <img src="data:{mime_type};base64,{encoded_data}" alt="Test Plot">
            </body>
            </html>"""
            
            # Basic HTML validation
            assert '<!DOCTYPE html>' in html, "Missing DOCTYPE in generated HTML"
            assert '<img' in html, "Missing img tag in generated HTML"
            assert 'src="data:' in html, "Missing data URI in img src attribute"
            
            # Verify the data URI can be decoded back to the original data
            decoded_data = base64.b64decode(encoded_data)
            assert decoded_data == image_data, "Data URI decoding failed"
            
            # Save the HTML to a file for manual inspection
            html_path = os.path.join(os.path.dirname(image_path), 'plot_embedding_test.html')
            with open(html_path, 'wb') as f:
                f.write(html.encode('utf-8'))
            
            result.add_test_case(
                name=test_name,
                passed=True,
                message=f"Successfully embedded {ext.upper()} image in HTML"
            )
            
        finally:
            # Clean up
            try:
                os.remove(image_path)
            except OSError:
                pass
            
    except AssertionError as e:
        result.add_test_case(
            name=test_name,
            passed=False,
            message=str(e),
            details=f"Code:\n{plot_code}"
        )
    except Exception as e:
        result.add_test_case(
            name=test_name,
            passed=False,
            message=f"Unexpected error: {str(e)}",
            details=f"Code:\n{plot_code}"
        )


def run_compliance_suite():
    """Run the complete compliance test suite."""
    print(f"{BOLD}Sage Filter Test Suite{RESET}")
    print(f"Python: {sys.version.split()[0]}")
    print(f"Working directory: {os.getcwd()}")
    print(f"Package directory: {PACKAGE_DIR}")
    
    # Check Sage version
    try:
        sage_version = subprocess.check_output(['sage', '--version']).decode().strip()
        print(f"Sage version: {sage_version}")
    except (subprocess.SubprocessError, FileNotFoundError):
        print(f"{YELLOW}Warning: Could not determine Sage version. Make sure 'sage' is in your PATH.{RESET}")
    
    print(f"\n{BOLD}Test Suite Summary{RESET}")
    start_time = datetime.now()
    print(f"Started at:  {start_time.isoformat()}")
    
    # Run all test modules
    all_results = []
    
    # List of all test modules to run
    test_modules = [
        # Core functionality tests
        'test_plot_generation',
        'test_html_embedding',
        'test_expectations',
        'test_pdf_output',
        'test_pdf_output_fixed',
        'test_sage_pdf_output',
        
        # Unit tests
        'unit.test_basic_math',
        
        # Integration tests
        'integration.test_symbolic_math',
        
        # Regression tests
        'regression.test_regressions',
    ]
    
    # Run all test modules
    for module_name in test_modules:
        try:
            all_results.extend(run_test_module(module_name))
        except ModuleNotFoundError as e:
            print(f"{YELLOW}Warning: Could not load test module {module_name}: {e}{RESET}")
    
    # Calculate statistics
    duration = datetime.now() - start_time
    total = len(all_results)
    passed = sum(1 for r in all_results if r.passed)
    failed = total - passed
    
    # Print detailed results
    print(f"\n{BOLD}Detailed Results:{RESET}")
    for i, result in enumerate(all_results, 1):
        status = f"{GREEN}✓{RESET}" if result.passed else f"{RED}✗{RESET}"
        print(f"{i:4d}. {result.name:60} {status} {result.duration:.3f}s")
        if not result.passed and result.error:
            print(f"      {RED}Error:{RESET} {result.error}")
    
    # Print summary
    print(f"\n{BOLD}Test Suite Summary{RESET}")
    print(f"Started at:  {start_time.isoformat()}")
    print(f"Duration:    {duration.total_seconds():.3f} seconds")
    print(f"Total tests: {total}")
    print(f"{GREEN}✓ Passed:     {passed}{RESET}")
    if failed > 0:
        print(f"{RED}✗ Failed:     {failed}{RESET}")
    success_rate = (passed / total * 100) if total > 0 else 0
    color = GREEN if success_rate > 90 else YELLOW if success_rate > 50 else RED
    print(f"{BOLD}Success rate:{RESET} {color}{success_rate:.1f}%{RESET}")
    
    # Exit with non-zero code if any tests failed
    sys.exit(1 if failed > 0 else 0)


if __name__ == "__main__":
    run_compliance_suite()
