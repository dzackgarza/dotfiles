#!/usr/bin/env bash
# fmt-pipeline: flowmark prose formatting + structural normalization
# Usage: fmt-pipeline <input.md>
set -euo pipefail

INPUT="$1"

FILTER_DIR="$(dirname "$(readlink -f "$0")")/../filters"

flowmark --semantic "$INPUT" 2>/dev/null \
| sed -E \
    -e 's/^(:::\{[^}]*\}) (.+)/\1\n\2/' \
    -e 's/\\\[\\/\\\[/g' \
| pandoc \
    -f 'markdown+fenced_divs+raw_tex+tex_math_dollars+tex_math_single_backslash+wikilinks_title_after_pipe' \
    -t 'markdown+wikilinks_title_after_pipe' \
    --lua-filter="$FILTER_DIR/normalize_displaymath.lua" \
    --lua-filter="$FILTER_DIR/normalize_fenced_divs.lua" \
    --wrap=none \
    2>/dev/null
