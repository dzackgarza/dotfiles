% DZG Unified Style Package
% Includes all tiers for full LaTeX/Pandoc documents
%
% Created 2025-01-09 as part of macro consolidation
% Replaces multiple \input{} statements with single \usepackage{dzg-unified}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{dzg-unified}[2025/01/09 DZG Unified Macro Package]

% Core math packages (required for macros to work)
\RequirePackage{amsmath,amsthm,amssymb,amsfonts}
\RequirePackage{mathtools}    % DeclarePairedDelimiter, coloneqq
\RequirePackage{mathrsfs}     % Script fonts
\RequirePackage{bm}           % Bold math
\RequirePackage{esint}        % Integral symbols
\RequirePackage{stmaryrd}     % Special brackets
\RequirePackage{upgreek}      % Upright Greek

% Graphics (conditional - may be loaded by document with options)
\@ifpackageloaded{graphicx}{}{\RequirePackage{graphicx}}
\@ifpackageloaded{xcolor}{}{\RequirePackage[dvipsnames]{xcolor}}

% TikZ and diagrams
\RequirePackage{tikz}
\RequirePackage{tikz-cd}

% Utilities (if not already loaded)
\@ifpackageloaded{etoolbox}{}{\RequirePackage{etoolbox}}
\@ifpackageloaded{xparse}{}{\RequirePackage{xparse}}

% NOTE: microtype, hyperref, cleveref, booktabs, enumitem, caption
% are NOT loaded here - they often require document-specific options
% and should be loaded by preambles or document class

% Set graphics path
\graphicspath{{~/figures/}}

% Tier 1: Simple MathJax-compatible shortcuts
\input{tier1-mathjax-simple}

% Tier 2: Commands with arguments (MathJax-compatible)
\input{tier2-mathjax-args}

% Tier 3: Complex TeX-specific commands
\input{tier3-tex-complex}

% Tier 4: Preamble content
\input{tier4-preamble}

% Domain-specific macros
\input{categories}
\input{spectral}
\input{tikz}
\input{environments}

\endinput
