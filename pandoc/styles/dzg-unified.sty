% DZG Unified Style Package
% Includes all tiers for full LaTeX/Pandoc documents
%
% Created 2025-01-09 as part of macro consolidation
% Replaces multiple \input{} statements with single \usepackage{dzg-unified}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{dzg-unified}[2025/01/09 DZG Unified Macro Package]

\newif\if@dzgarxiv
\@dzgarxivfalse
\DeclareOption{arxiv}{\@dzgarxivtrue}
\ProcessOptions\relax

% Shared package loading
\input{preambles/dzg-preamble}

% Tables and Floats
\RequirePackage{longtable}
\RequirePackage{array}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{placeins}
\RequirePackage{float}
\RequirePackage[export]{adjustbox}
\RequirePackage{caption}
\RequirePackage{subcaption}
\RequirePackage{epstopdf}
\RequirePackage{svg}

% Typography and Layout
\RequirePackage{etex}
\RequirePackage{hyphenat}
\RequirePackage{indentfirst}
\RequirePackage{csquotes}
\RequirePackage{url}
\RequirePackage{datetime}
\RequirePackage{marginnote}
\RequirePackage[textsize=tiny]{todonotes}

% Page geometry (personal default)
\RequirePackage{geometry}
\geometry{margin=1in}

\RequirePackage{dzg-macros}

% Spectral sequences diagram package
\RequirePackage{spectralsequences}

\if@dzgarxiv
  \input{environments-arxiv}
\else
  \input{environments}
\fi

% Bibliography with personal defaults
\RequirePackage[backend=biber, style=alphabetic]{biblatex}

% Pandoc figure compatibility macros (unconditional)
\makeatletter
\def\maxwidth{\ifdim\Gin@nat@width>\textwidth\textwidth\else\Gin@nat@width\fi}
\def\maxheight{\ifdim\Gin@nat@height>\textheight\textheight\else\Gin@nat@height\fi}
\def\fps@figure{H}
\newcommand{\pandocbounded}[1]{#1}
\makeatother
\setkeys{Gin}{width=\maxwidth,height=\maxheight,keepaspectratio}

% Cleveref: must be loaded last (hooks into other packages' references)
\RequirePackage{cleveref}
\crefname{figure}{fig.}{figs.}
\Crefname{figure}{Fig.}{Figs.}
\crefname{equation}{equation}{eqns.}
\Crefname{equation}{Equation}{Eqns.}
\crefname{section}{section}{secs.}
\Crefname{section}{Section}{Secs.}

% Pandoc compatibility
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

\endinput
