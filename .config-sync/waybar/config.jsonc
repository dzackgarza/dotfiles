{
  "height": 30,
  "font": "Symbols Nerd Font 10",
  "spacing": 4,
  "modules-left": [
    "sway/mode",
    "sway/workspaces",
    "sway/scratchpad",
    "custom/books",
    "custom/apps",
    "custom/osk",
    "custom/printscreen"
  ],
  "modules-center": [
    "clock",
    "custom/network-static",
    "custom/claude-usage"
  ],
  "modules-right": [
    "pulseaudio",
    "cpu",
    "memory",
    :qa
    "temperature",
    "battery",
    "tray"
  ],
  "sway/mode": {
    "format": "<span style=\"italic\">´î× {}</span>"
  },
  "sway/workspaces": {
    "all-outputs": false,
    "disable-scroll": false,
    "format": "{name}",
    "format-icons": {
      "A1": "\uf120",
      "A2": "\uf269",
      "3": "\uf121",
      "A3": "\uf121",
      "A4": "\uf198",
      "A5": "\uf1fc",
      "B1": "\uf111",
      "B2": "\uf111",
      "B3": "\uf111",
      "B4": "\uf111",
      "B5": "\uf02d",
      "urgent": "\uf06a",
      "active": "\uf192",
      "focused": "\uf192",
      "default": "\uf111"
      "empty": "\uf111"
    }
  },
  "clock": {
    "interval": 1,
    "format": "{:%a %b %d %H:%M:%S}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "{}% ´őŤ",
    "tooltip": false
  },
  "memory": {
    "format": "{}% ´âë"
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C ´őë",
    "format-critical": "{temperatureC}┬░C ´őç"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 20,
      "critical": 5
    },
    "format": "{capacity}% {icon} {power:.2f}W {time}",
    "format-charging": "{capacity}% ´Śž {power:.2f}W {time}",
    "format-plugged": "{capacity}% ´çŽ {power:.2f}W {time}",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ]
  },
  "network": {
    "format-wifi": "{essid} ({signalStrength}%) ´çź {ipaddr}/{cidr}",
    "format-ethernet": "{ifname} ´âü {ipaddr}/{cidr}",
    "format-disconnected": "Disconnected",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
    "format-muted": "´Üę {format_source}",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´ľÉ",
      "headset": "´ľÉ",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": [
        "´ÇŽ",
        "´Çž",
        "´ÇĘ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "tray": {
    "spacing": 10
  },
  "custom/osk": {
    "format": "ÔîĘ Keyboard",
    "tooltip": false,
    "on-click": "exec toggle_osk.sh"
  },
  "custom/books": {
    "format": "­čĽ«  Books",
    "tooltip": false,
    "on-click": "exec dmenuAllPDFs.sh"
  },
  "custom/apps": {
    "format": "­čĺ╗ Apps",
    "tooltip": false,
    "on-click": "exec nwggrid"
  },
  "custom/printscreen": {
    "format": "Screen Clip",
    "tooltip": false,
    "on-click": "exec grim -g \"$(slurp)\" - | wl-copy"
  },
  "custom/claude-usage": {
        "format": "ˇ░Üę",
        "on-click": "ags toggle claude-usage"
  },
  //"custom/network-static": {
    //"exec": "cd /home/dzack/gitclones/sway_modules/traffic-hs-simple && /usr/local/bin/stack exec traffic-hs",
    //"return-type": "json",
    //"interval": 1
  //}
}
