{
    //_________\\ Default Modules //_________\\

    // taskbar
    "wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    // network
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "󰌘",
        "tooltip-format": "Network: <big><b>{essid}</b></big>
Signal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>
Frequency: <b>{frequency}MHz</b>
Interface: <b>{ifname}</b>
IP: <b>{ipaddr}/{cidr}</b>
Gateway: <b>{gwaddr}</b>
Netmask: <b>{netmask}</b>",
        "format-linked": "󰈀 {ifname} (No IP)",
        "format-disconnected": "󰖪 ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "max-length": 30,
    	"format-icons": [
    		"󰤯", "󰤟", "󰤢", "󰤥", "󰤨"
    	],
        "on-click": "nm-connection-editor",
        "on-click-right": "kitty -e nmtui"
    },

    // network speed
    "network#speed": {
        "format": "<span foreground='#99ffdd'> {bandwidthDownBytes}</span> <span foreground='#ffcc66'> {bandwidthUpBytes}</span>",
        "format-disconnected": "󰖪 ",
        "tooltip": false,
        "interval": 1,
        "max-length": 30,
    	"format-icons": [
    		"󰤯", "󰤟", "󰤢", "󰤥", "󰤨"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // idle inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "start-activated": true,
            "format-icons": {
                "activated": "",
                "deactivated": "󰛊"
            },
        "tooltip-format-activated":"Caffeine Mode: Active \nNothing will be happen.",
        "tooltip-format-deactivated":"Caffeine Mode: Inactive\n\nIf there is no interaction with your\nsystem (mouse/keyboard), then \nScreen Lock: after 5 min \nScreen Off: after 10 min \nSleep: after 30 min"
    },

    // window
    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true,
        "rewrite": {
            "(.*)${USER}@${set_sysname}:(.*)": "$1  :$2",
            "(.*) — Mozilla Firefox": "$1 󰈹",
            "(.*)Mozilla Firefox": "$1 Firefox 󰈹",
            "(.*) - Visual Studio Code": "$1 󰨞",
            "(.*)Visual Studio Code": "$1 Code 󰨞",
            "(.*) — Dolphin": "$1 󰉋",
            "(.*)Spotify.*": "$1 Spotify 󰓇",
            "(.*)Steam": "$1 Steam 󰓓",
            "(.*) - Discord": "$1  ",
            "(.*?)-\\s*YouTube(.*)": "$1󰗃", 
            "(.*?\\s)YouTube(.*)": "$1YouTube 󰗃"
        },
        "max-length": 50
    },

    // language
    "hyprland/language": {
        "interval": 1,
        "format": " {}",
        "format-uk": "Uk",
        "format-en": "US"
    },

    // workspaces
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "markup": true,
        "format": "",
        "format-icons": {
            "1": "A1",
            "2": "A2",
            "3": "A3",
            "4": "A4",
            "5": "A5",
            "6": "<span foreground='#89b4fa'>B1</span>",
            "7": "<span foreground='#89b4fa'>B2</span>",
            "8": "<span foreground='#89b4fa'>B3</span>",
            "9": "<span foreground='#89b4fa'>B4</span>",
            "10": "<span foreground='#89b4fa'>B5</span>",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "eDP-1": [1, 2, 3, 4, 5],
            "DP-5": [6, 7, 8, 9, 10]
        }
    },

    //------took it from JaKooLit-------//

    "hyprland/workspaces#preview": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        },
        "format": "{icon} {windows}",
        "format-icons": {
            "1": "A1",
            "2": "A2",
            "3": "A3",
            "4": "A4",
            "5": "A5",
            "6": "B1",
            "7": "B2",
            "8": "B3",
            "9": "B4",
            "10": "B5"
        },
        "format-window-separator": "",
        "window-rewrite-default": " ",
        "window-rewrite": {		
            "title<.*amazon.*>": " ",
            "title<.*reddit.*>": " ",

            "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": " ",
            "class<zen>": "󰰷 ",
            "class<waterfox|waterfox-bin>": " ",
            "class<microsoft-edge>": " ",
            "class<Chromium|Thorium|[Cc]hrome>": " ",
            "class<brave-browser>": "🦁 ",
            "class<tor browser>": " ",
            "class<firefox-developer-edition>": "󰈹 ",

            "class<kitty|konsole>": "󰄛 ",
            "class<kitty-dropterm>": " ",
            "class<com.mitchellh.ghostty>": " ",
            "class<org.wezfurlong.wezterm>": " ",

            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": " ",
            "class<eu.betterbird.Betterbird>": " ",
            "title<.*gmail.*>": "󰊫 ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": " ",
            "class<discord|[Ww]ebcord|Vesktop>": " ",
            "title<.*whatsapp.*>": " ",
        "title<.*zapzap.*>": " ",
            "title<.*messenger.*>": " ",
            "title<.*facebook.*>": " ",
            "title<.*instagram.*>": "󰋾 ",
            "title<.*reddit.*>": " ",


            "title<.*ChatGPT.*>": "󰚩 ",
            "title<.*deepseek.*>": "󰚩 ",
            "title<.*qwen.*>": "󰚩 ",
            "class<subl>": "󰅳 ",
            "class<slack>": " ",

            "class<mpv>": " ",
            "class<celluloid|Zoom>": " ",
            "class<Cider>": "󰎆 ",
            "title<.*Picture-in-Picture.*>": " ",
            "title<.*youtube.*>": " ",
            "class<vlc>": "󰕼 ",
            "title<.*cmus.*>": " ",
            "class<[Ss]potify>": " ",

            "class<virt-manager>": " ",
            "class<.virt-manager-wrapped>": " ",
            "class<virtualbox manager>": "💽 ",
            "title<virtualbox>": "💽 ",
            "class<remmina>": "🖥️ ",

            "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium|code>": "󰨞 ",
        "class<dev.zed.Zed>": "󰵁",
            "class<codeblocks>": "󰅩 ",
            "title<.*github.*>": " ",
            "class<mousepad>": " ",
            "class<libreoffice-writer>": " ",
            "class<libreoffice-startcenter>": "󰏆 ",
            "class<libreoffice-calc>": " ",
            "title<.*nvim ~.*>": " ",
            "title<.*vim.*>": " ",
            "title<.*nvim.*>": " ",
            "title<.*figma.*>": " ",
            "title<.*jira.*>": " ",
            "class<jetbrains-idea>": " ",

            "class<obs|com.obsproject.Studio>": " ",

            "class<polkit-gnome-authentication-agent-1>": "󰒃 ",
            "class<nwg-look>": " ",
            "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "󱡫 ",
            "class<steam>": " ",
            "class<thunar|nemo>": "󰝰 ",	
        "class<Gparted>":"",
            "class<gimp>": " ",
            "class<emulator>": "📱 ",
            "class<android-studio>": " ",
        "class<org.pipewire.Helvum>": "󰓃",
        "class<localsend>":"",
        "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "󰹛",
            }
    },

    // cpu
    "cpu": {
        "interval": 5,
        "format": "{icon0}{icon1}{icon2}{icon3} {usage}%",
        "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
    },

    // memory
    "memory": {
        "interval": 5,
        "format": " {used:0.1f}/{total:0.1f}GB"
    },

    // dik
    "disk": {
        "interval": 60,
        "format": " {free}",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "Storage - {used} used out of {total} on {path} ({percentage_used}%)"
    },

    // temperature
    "temperature": {
        "thermal-zone": 1,
        "format": " {temperatureC}°C",
        "critical-threshold": 70,
        "format-critical": " {temperatureF}°F",
        "on-click": "kitty --title btop sh -c 'btop'"
    },
    
    // backlight
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            " ",
            " ",
            " ",
            "󰃝 ",
            "󰃞 ",
            "󰃟 ",
            "󰃠 "
        ],
        "tooltip-format": "backlight {percent}%",
        "icon-size": 10,
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "~/.config/hypr/scripts/brightness.sh up",
        "on-scroll-down": "~/.config/hypr/scripts/brightness.sh down",
        "smooth-scrolling-threshold": 1
    },

    // tray
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    // clock
    "clock": {
        "format": " {:%a %m/%d/%y %H:%M}",
        "on-click": "exec gnome-calendar",
        "tooltip": true,
        "tooltip-format": "<span>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    // battery
    "battery": {
	//"interval": 5,
	"align": 0,
	"rotate": 0,
	"full-at": 100,
	"design-capacity": false,
	"states": {
		"good": 95,
		"warning": 30,
		"critical": 15
	},
	"format": "{icon} {capacity}% {power:.2f}W {time}",
	"format-charging": " {capacity}% {power:.2f}W {time}",
	"format-plugged": "󱘖 {capacity}% {power:.2f}W {time}",
	"format-full": "{icon} Full",
	"format-icons": [
		"󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"
	    ],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w",
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "orientation": "vertical"
    },

    // pulseaudio
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " ",
        "tooltip": false,
        "on-click": "~/.config/hypr/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "default": ["", "", " "]
        }
    },

    // pulseautio mic
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "on-click": "~/.config/hypr/scripts/volumecontrol.sh --toggle-mic",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --mic-inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --mic-dec",
        "scroll-step": 5
    },

    // mpris ( media player )
    "mpris": {
        "interval": 2,
        "format": "{player_icon}  {status_icon}",
        "format-paused": "{player_icon}  {status_icon}",
        "tooltip": true,
        "tooltip-format": "{dynamic}",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "scroll-step": 5.0,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "smooth-scrolling-threshold": 1,
        "player-icons": {
            "chromium": "",
            "default": "",
            "firefox": "",
            "kdeconnect": "",
            "mopidy": "",
            "mpv": "󰐹",
            "spotify": "",
            "vlc": "󰕼"
        },
        "status-icons": {
            "paused": "󰏤 ",
            "playing": " ",
            "stopped": ""
        },
        "max-length": 30
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "",
        "performance": "",
        "balanced": "",
        "power-saver": ""
      }
    },

    // "user": {
    //     "format": "{user}",
    //     "interval": 60,
    //     "height": 30,
    //     "width": 30,
    //     "icon": true,
    // },

    // keyboard status - disabled in favor of custom script
    // "keyboard-state": {
	// "numlock": true,
	// "capslock": true,
	// "format": "{name} {icon}",
	// "format-icons": {
		// "locked": "🔒",
		// "unlocked": "🔓"
	// }
    // },
}
